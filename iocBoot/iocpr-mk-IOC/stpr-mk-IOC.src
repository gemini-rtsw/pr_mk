$(LINUX_ONLY)#!/gem_base/epics/ioc/pr_mk/bin/${ARCH}/pr-mk-IOC

cd /gem_base/epics/ioc/pr_mk
epicsEnvSet("IOCSH_PS1","pr-mk-ioc> ")

## Register all support components
dbLoadDatabase("dbd/pr-mk-IOC.dbd")
pr_mk_IOC_registerRecordDeviceDriver(pdbbase)

## Load PLC scan tables
devMgrInit "data/prplc.cfg"

## Load record instances
dbLoadRecords "db/pr-mk-IOC.db"
dbLoadRecords "db/platformLift.db"
#dbLoadRecords("db/iocAdminSoft.db"," IOC=pr:iocStats,TODFORMAT=%m/%d/%Y %H:%M:%S")

ornlPLC5ShowMsgs 1
ornlPLC5DebugOn 3

iocInit

pvload "./data/emhcInstr.pv", "top=prv:"
pvload "./data/emhcInstrList.pv", "num=A", "top=prv:"
pvload "./data/emhcInstrList.pv", "num=B", "top=prv:"
pvload "./data/emhcInstrList.pv", "num=C", "top=prv:"
pvload "./data/emhcInstrList.pv", "num=D", "top=prv:"
pvload "./data/emhcInstrList.pv", "num=E", "top=prv:"
pvload "./data/emhcInstrList.pv", "num=F", "top=prv:"
pvload "./data/emhcInstrList.pv", "num=G", "top=prv:"
pvload "./data/emhcInstrList.pv", "num=H", "top=prv:"
pvload "./data/emhcInstrList.pv", "num=I", "top=prv:"
pvload "./data/emhcInstrList.pv", "num=J", "top=prv:"
pvload "./data/emhcInstrList.pv", "num=K", "top=prv:"
pvload "./data/emhcInstrList.pv", "num=L", "top=prv:"
pvload "./data/emhcInstrList.pv", "num=M", "top=prv:"
pvload "./data/emhcInstrList.pv", "num=N", "top=prv:"
pvload "./data/emhcInstrList.pv", "num=O", "top=prv:"

## Start any sequence programs
#seq(sncxxx, "user=tcumming")
