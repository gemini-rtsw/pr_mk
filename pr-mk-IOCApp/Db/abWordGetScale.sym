[symbol2]
bbox 32 32 256 160
port 160 128 100 0 wordOut symbol 2 256 128 0
port 192 64 100 0 flnk symbol 2 256 64 0
uniq 768
[tools]
[attributes]
p 32 -32 100 0 1 setAb:ab /tyCo/1 41
p 32 -96 100 0 1 setCalc:calc A
p 32 -64 100 0 1 setDev:dev
p 144 -128 100 0 -1 setHHSV:hhsv NO_ALARM
p 144 -160 100 0 -1 setHSV:hsv NO_ALARM
p 32 -160 100 0 -1 setHigh:high 0.0
p 32 -128 100 0 -1 setHihi:hihi 0.0
p 144 -224 100 0 -1 setLLSV:llsv NO_ALARM
p 144 -192 100 0 -1 setLSV:lsv NO_ALARM
p 32 -224 100 0 -1 setLolo:lolo 0.0
p 32 -192 100 0 -1 setLow:low 0.0
p 32 0 100 0 1 setWord:word 0
[layers]
<symbol>
l 100 0 0 48 48 abWordGetScale
r 0 32 32 256 160
[comments]
